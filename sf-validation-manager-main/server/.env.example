# Salesforce Connected App Credentials
# Get these from your Salesforce Developer Org → Setup → App Manager → Connected App

SF_CLIENT_ID=your_consumer_key_here
SF_CLIENT_SECRET=your_consumer_secret_here

# Callback URL - must match exactly what you set in Connected App
SF_CALLBACK_URL=http://localhost:5000/auth/callback

# Session secret - change this to a random string
SESSION_SECRET=your_random_session_secret_here_change_this

# Port for backend server
PORT=5000
